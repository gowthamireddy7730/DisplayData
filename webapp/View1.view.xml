<mvc:View
    controllerName="registrationform.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page title="User Registration" showNavButton="true" navButtonPress="onNavBack">

        <!-- Home Button -->
        <headerContent>
            <Button icon="sap-icon://home" press="onHomePress"/>
        </headerContent>

        <content>
            <VBox class="sapUiSmallMargin">
                
                <Label text="Name : "/>
                <Input id="name" value="{/user/name}" placeholder="Enter Name"/>
                <Label text="Email : "/>
                <Input id="email" value="{/user/email}" placeholder="Enter Email"/>
                <Label text="Password : "/>
                <Input id="password" value="{/user/password}" type="Password" placeholder="Enter Password"/>
                <Label text="City : "/>
                <Input id="city" value="{/user/city}" placeholder="Enter City"/>
                <Label text="Phone : "/>
                <Input id="phone" value="{/user/phone no}" placeholder="Enter Phone"/>

                <HBox class="sapUiSmallMarginTop">
                    <Button text="Submit" press="onSubmit"/>
                    <Button text="Delete" press="onDelete"/>
                </HBox>

                <!-- Image -->
                <Image id="img" src="https://via.placeholder.com/150" visible="false"/>

            </VBox>
        </content>
    </Page>
</mvc:View>