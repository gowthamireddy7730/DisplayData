<mvc:View
    controllerName="registrationform.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout">
     <Page id="page">
        <subHeader>
            <Bar id="headerBar">

                <contentLeft>
                    <HBox>
                        <Button icon="sap-icon://nav-back"  press="onNavBack"/>
                        <Button text="Home" icon="sap-icon://home" press="onHomePress" class="homeButton"/>
                    </HBox>
                </contentLeft>

                <contentMiddle>
                    <Title text="User Registration Form" />
                </contentMiddle>

                <contentRight>
                    <HBox>
                        <Button text="Show Image" press="onShowImage" class="showImage"/>
                    </HBox>
                </contentRight>

            </Bar>
        </subHeader>

        <content>
            <VBox class="sapUiSmallMargin">

                <Label text="Name : "/>
                <Input value="{userModel>/user/name}"/>

                <Label text="Email : "/>
                <Input value="{userModel>/user/email}"/>

                <Label text="City : "/>
                <Input value="{userModel>/user/city}"/>

                <Label text="Phone : "/>
                <Input value="{userModel>/user/phone}"/>
                
                <Image title="Elephant" id="img" src="registrationform/images/Elephant.jpeg" width="900px" height="600px" visible="false" class="sapUiSmallMarginTop" />
                <Button id="btnBack" text="Back" visible="false" press="onBackFromImage" class="sapUiSmallMarginTop"/>
                
                <Panel id="mountainsPanel" headerText="Mountains Data" layoutData="{span:'L12 M12 S12'}" class="sapUiMediumMarginTop" visible="false">
                    <Table items="{mountainModel>/mountains}">
                            <columns>
                                <Column><Text text="Name"/></Column>
                                <Column><Text text="Height"/></Column>
                            </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{mountainModel>name}"/>
                                    <Text text="{mountainModel>height}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </content>

        <footer>
            <Toolbar>
                <HBox class="sapUiSmallMarginTop" justifyContent="SpaceBetween" alignItems="End" width="100%">
                    <Button text="Delete" press="onDelete" class="deleteButton"/>
                    <Button text="Submit" press="onSubmit" class="submitButton"/>
                </HBox>
            </Toolbar>
        </footer>
    </Page>
</mvc:View>